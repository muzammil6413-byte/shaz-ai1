<!DOCTYPE html>
<html>
<head>
<title>Shaz AI Studio</title>
<style>
body{
font-family:Arial,sans-serif;
background:#f4f4f4;
margin:0;
}

header{
background:#10a37f;
color:white;
padding:15px;
text-align:center;
}

.container{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
padding:20px;
}

.card{
background:white;
padding:20px;
border-radius:10px;
box-shadow:0 2px 10px rgba(0,0,0,.1);
text-align:center;
}

button{
background:#10a37f;
color:white;
border:none;
padding:10px 20px;
border-radius:5px;
cursor:pointer;
}
</style>
</head>
<body>

<header>
<h1>🚀 Shaz AI Studio</h1>
</header>

<div class="container">

<div class="card">
<h2>💬 AI Chat</h2>
<button>Open</button>
</div>

<div class="card">
<h2>🎥 AI Video Generator</h2>
<button>Create Video</button>
</div>

<div class="card">
<h2>🖼 AI Image Generator</h2>
<button>Generate Image</button>
</div>

<div class="card">
<h2>🎤 Text To Speech</h2>
<button>Convert Voice</button>
</div>

<div class="card">
<h2>📄 Script Writer</h2>
<button>Write Script</button>
</div>

<div class="card">
<h2>📺 YouTube Shorts Creator</h2>
<button>Create Shorts</button>
</div>

</div>

</body>
</html>
